# EMBEDHUNT AI — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="EMBEDHUNT AI"
APP_VERSION="0.1.0"
APP_ENV=development
DEBUG=true

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING_IN_PRODUCTION

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://embedhunt:embedhunt@localhost:5432/embedhunt

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Email (optional for Phase A) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM=noreply@embedhunt.ai

# ─── AI (Phase C) ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=text
